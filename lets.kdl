description "Git manager"

build "cargo build --workspace" description="Build the workspace"
check "cargo fmt --all -- --check" description="Run cargo checks"
test "cargo test --workspace" description="Run tests"
lint "cargo clippy --workspace --all-targets -- -D warnings" description="Run clippy"
fmt "cargo fmt --all" description="Format code"
clean "cargo clean" description="Clean repo"
hooks "cog install-hook --all" description="Install cocogitto git hooks locally"
changelog "cog changelog" description="Preview the changelog from conventional commits"
bump:patch "cog bump --auto" description="Bump version, update changelog, commit, and tag a patch release"
bump:minor "cog bump --auto minor" description="Bump version, update changelog, commit, and tag a minor release"
bump:major "cog bump --auto major" description="Bump version, update changelog, commit, and tag a major release"
